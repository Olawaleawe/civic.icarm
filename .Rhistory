ui <- fluidPage(
titlePanel("Socio-Demographic Dashboard"),
sidebarLayout(
sidebarPanel(
selectInput("var", "Select Variable:",
choices = c("Age","Income","Racism_Impact","Number_of_Friends")),
selectInput("color", "Color By:",
choices = c("Gender","Area_Type","Education_Level"))
),
mainPanel(
plotOutput("plot1"),
tableOutput("summary1")
)
)
)
server <- function(input, output) {
output$plot1 <- renderPlot({
ggplot(dataset1, aes_string(x=input$var, color=input$color)) +
geom_histogram(fill="steelblue", alpha = .6, bins=20) +
theme_minimal()
})
output$summary1 <- renderTable({
dataset1 %>% summarise(
Mean = mean(.data[[input$var]], na.rm=TRUE),
SD = sd(.data[[input$var]], na.rm=TRUE),
Min = min(.data[[input$var]], na.rm=TRUE),
Max = max(.data[[input$var]], na.rm=TRUE)
)
})
}
