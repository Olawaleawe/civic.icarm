summary(model3)
###############################################################################
#   COMPREHENSIVE DATA GENERATION + VISUALIZATION SCRIPT
#   Author: Prof. Olushina Olawale Awe
#   Description: Generates a synthetic socio-demographic dataset (n = 150)
#                and produces a wide variety of statistical visualizations.
###############################################################################
# ============================
# 1. Load Required Libraries
# ============================
library(ggplot2)
library(dplyr)
library(tidyr)
#library(GGally)
library(ggridges)
library(forcats)
set.seed(123)   # Reproducibility
# ============================
# 2. Generate Synthetic Dataset
# ============================
n <- 150  # participants
age <- sample(18:75, n, replace = TRUE)
gender <- sample(c("male", "female", "diverse"), n, replace = TRUE, prob = c(0.45, 0.45, 0.1))
hair_color <- sample(c("blonde", "brown", "black", "other"), n, replace = TRUE, prob = c(0.25, 0.4, 0.25, 0.05))
skin_color <- sample(c("light", "medium", "dark"), n, replace = TRUE, prob = c(0.55, 0.3, 0.15))
relationship_status <- sample(c("single", "Engaged", "married"), n, replace = TRUE, prob = c(0.4, 0.4, 0.2))
racism_impact <- sample(0:10, n, replace = TRUE)
police_stop <- sample(c("0 times", "1 time", "2 or more times"), n, replace = TRUE, prob = c(0.6, 0.25, 0.15))
migrant_status <- sample(c("Yes", "No"), n, replace = TRUE, prob = c(0.3, 0.7))
income <- sample(1000:10000, n, replace = TRUE) * rbeta(n, 1, 5)
education <- sample(c("High School", "Bachelor's", "Master's", "Doctorate"), n, replace = TRUE,
prob = c(0.2, 0.4, 0.3, 0.1))
employment_status <- sample(c("Employed", "Unemployed", "Student", "Retired"), n, replace = TRUE,
prob = c(0.6, 0.2, 0.15, 0.05))
area_type <- sample(c("Urban", "Rural"), n, replace = TRUE, prob = c(0.75, 0.25))
religion <- sample(c("Christian", "Muslim", "Other", "Not Religious"), n, replace = TRUE,
prob = c(0.4, 0.3, 0.2, 0.1))
language_proficiency <- sample(c("None", "Basic", "Intermediate", "Fluent"), n, replace = TRUE,
prob = c(0.05, 0.2, 0.4, 0.35))
num_friends <- sample(0:10, n, replace = TRUE)
political_orientation <- sample(0:3, n, replace = TRUE)
dataset1 <- data.frame(
ID = 1:n,
Age = age,
Gender = gender,
Hair_Color = hair_color,
Skin_Color = skin_color,
Relationship_Status = relationship_status,
Racism_Impact = racism_impact,
Police_Stop = police_stop,
Migrant_Status = migrant_status,
Income = income,
Education_Level = education,
Employment_Status = employment_status,
Area_Type = area_type,
Religion = religion,
Language_Proficiency = language_proficiency,
Number_of_Friends = num_friends,
Political_Orientation = political_orientation
)
head(dataset1)
# ============================
# 3. VISUALIZATIONS
# ============================
# Histogram: Age
ggplot(dataset1, aes(Age)) +
geom_histogram(bins = 20, fill = "steelblue", color = "white") +
theme_minimal() + labs(title = "Distribution of Age")
# Histogram: Income
ggplot(dataset1, aes(Income)) +
geom_histogram(bins = 30, fill = "darkorange", color = "white") +
theme_minimal() + labs(title = "Distribution of Income")
# Density Plot: Income
ggplot(dataset1, aes(Income)) +
geom_density(fill = "purple", alpha = 0.4) +
theme_minimal() + labs(title = "Income Density")
# Bar Charts: Gender / Hair Colour / Education Level
ggplot(dataset1, aes(Gender)) + geom_bar(fill = "seagreen") +
theme_minimal() + labs(title = "Gender Distribution")
ggplot(dataset1, aes(Hair_Color)) + geom_bar(fill = "tomato") +
theme_minimal() + labs(title = "Hair Colour Distribution")
ggplot(dataset1, aes(Education_Level)) + geom_bar(fill = "gold") +
theme_minimal() + labs(title = "Education Level Distribution")
# Boxplots
ggplot(dataset1, aes(Gender, Income)) + geom_boxplot(fill = "skyblue") +
theme_minimal() + labs(title = "Income by Gender")
ggplot(dataset1, aes(Migrant_Status, Racism_Impact)) + geom_boxplot(fill = "orangered") +
theme_minimal() + labs(title = "Racism Impact vs Migrant Status")
# Violin Plot
ggplot(dataset1, aes(Area_Type, Income)) +
geom_violin(fill = "violet", alpha = 0.6) +
theme_minimal() + labs(title = "Income by Area Type")
# Scatterplots
ggplot(dataset1, aes(Age, Income)) +
geom_point(alpha = 0.6, color = "blue") +
theme_minimal() + labs(title = "Age vs Income")
ggplot(dataset1, aes(Number_of_Friends, Racism_Impact)) +
geom_point(alpha = 0.6, color = "darkred") +
theme_minimal() + labs(title = "Friends vs Racism Impact")
# Scatterplot + Regression
ggplot(dataset1, aes(Age, Income)) +
geom_point(alpha = 0.5) + geom_smooth(method = "lm", color = "red") +
theme_minimal() + labs(title = "Income vs Age (Regression Line)")
# Faceted Density: Income by Gender & Area Type
ggplot(dataset1, aes(Income, fill = Gender)) +
geom_density(alpha = 0.4) +
facet_wrap(~Area_Type) +
theme_minimal() + labs(title = "Income by Gender & Area Type")
# Count Plots
ggplot(dataset1, aes(Gender, fill = Migrant_Status)) +
geom_bar(position = "dodge") + theme_minimal() +
labs(title = "Gender vs Migrant Status")
ggplot(dataset1, aes(Skin_Color, fill = Police_Stop)) +
geom_bar(position = "dodge") + theme_minimal() +
labs(title = "Police Stop by Skin Colour")
# Heatmap
dataset1 %>% count(Relationship_Status, Education_Level) %>%
ggplot(aes(Relationship_Status, Education_Level, fill = n)) +
geom_tile() + scale_fill_gradient(low="white", high="blue") +
theme_minimal() + labs(title = "Relationship Status vs Education")
# Correlation Matrix
num_data <- dataset1 %>%
dplyr::select(Age, Racism_Impact, Income, Number_of_Friends, Political_Orientation)
# Correlation matrix
cor_mat <- cor(num_data, use = "complete.obs")
# Turn into tidy data frame for ggplot
cor_df <- as.data.frame(as.table(cor_mat))
colnames(cor_df) <- c("Var1", "Var2", "Correlation")
ggplot(cor_df, aes(Var1, Var2, fill = Correlation)) +
geom_tile() +
scale_fill_gradient2(limits = c(-1, 1)) +
theme_minimal() +
labs(title = "Correlation Matrix", x = "", y = "") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Boxplot: Racism Impact by Skin Colour
ggplot(dataset1, aes(Skin_Color, Racism_Impact, fill = Skin_Color)) +
geom_boxplot() + theme_minimal() + labs(title = "Racism Impact by Skin Colour")
# Lollipop Chart: Religion
dataset1 %>% count(Religion) %>%
ggplot(aes(fct_reorder(Religion, n), n)) +
geom_segment(aes(xend = Religion, y = 0, yend = n)) +
geom_point(size = 4, color="darkgreen") +
coord_flip() + theme_minimal() +
labs(title = "Religion Distribution")
# Pie Chart: Employment Status
dataset1 %>% count(Employment_Status) %>%
ggplot(aes(x="", y=n, fill=Employment_Status)) +
geom_col(width=1) + coord_polar("y") + theme_void() +
labs(title = "Employment Status Breakdown")
# Ridgeline Plot
ggplot(dataset1, aes(Income, Education_Level, fill = Education_Level)) +
geom_density_ridges(alpha=0.6) +
theme_minimal() + labs(title = "Income by Education Level")
# Multivariate Scatterplot
ggplot(dataset1, aes(Age, Income, color=Gender, size=Number_of_Friends)) +
geom_point(alpha=0.7) + theme_minimal() +
labs(title = "Income vs Age (Colored by Gender, Sized by Friends)")
# Political Orientation Bar Plot
ggplot(dataset1, aes(Political_Orientation)) +
geom_bar(fill="darkblue") + theme_minimal() +
labs(title = "Political Orientation")
# ============================
# 4. Regression Models
# ============================
# --- 4.1 Linear Regression: Income ~ Age + Gender + Education
model1 <- lm(Income ~ Age + Gender + Education_Level, data = dataset1)
summary(model1)
plot(model1)
# --- 4.3 Ordinal Regression: Political Orientation
# Requires MASS package
library(MASS)
model3 <- polr(as.factor(Political_Orientation) ~ Age + Gender, data=dataset1, Hess=TRUE)
summary(model3)
# ============================
# 5. ANOVA
# ============================
# --- ANOVA: Is income different across education levels?
anova_model <- aov(Income ~ Education_Level, data = dataset1)
summary(anova_model)
# Post-hoc Tukey Test
TukeyHSD(anova_model)
# ============================
# 6. Modern Machine Learning
library(caret)
library(dplyr)
library(pROC)
library(randomForest)
library(gbm)
set.seed(123)
#==========================================================
# 1. PREPARE DATA
#==========================================================
data <- dataset1 %>% mutate(across(where(is.character), as.factor))
# Train–test split
trainIndex <- createDataPartition(data$Income, p = 0.7, list = FALSE)
train <- data[trainIndex, ]
test  <- data[-trainIndex, ]
# Cross-validation setup
ctrl_reg <- trainControl(method = "cv", number = 10)
ctrl_clf <- trainControl(method = "cv", number = 10,
classProbs = TRUE, summaryFunction = twoClassSummary)
#---- Linear Regression
lm_model <- train(
Income ~ Age + Gender + Education_Level + Area_Type,
data = train, method = "lm", trControl = ctrl_reg
)
lm_pred <- predict(lm_model, test)
postResample(lm_pred, test$Income)
#---- Random Forest Regression
rf_model <- train(
Income ~ Age + Gender + Education_Level + Area_Type,
data = train, method = "rf", tuneLength = 5, trControl = ctrl_reg
)
rf_pred <- predict(rf_model, test)
postResample(rf_pred, test$Income)
varImp(rf_model)
#---- Gradient Boosting Regression (GBM)
gbm_model <- train(
Income ~ Age + Gender + Education_Level + Area_Type,
data = train, method = "gbm", trControl = ctrl_reg, verbose = FALSE
)
gbm_pred <- predict(gbm_model, test)
postResample(gbm_pred, test$Income)
# Convert response to binary factor
data$Migrant_Status <- factor(data$Migrant_Status, levels = c("No","Yes"))
train <- data[trainIndex, ]
test  <- data[-trainIndex, ]
#---- Logistic Regression
logit_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "glm", family = "binomial",
trControl = ctrl_clf, metric = "ROC"
)
logit_pred <- predict(logit_model, test)
confusionMatrix(logit_pred, test$Migrant_Status)
# ROC
logit_prob <- predict(logit_model, test, type="prob")
roc(test$Migrant_Status, logit_prob$Yes)
#---- K-Nearest Neighbors
knn_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "knn", tuneLength = 10,
trControl = ctrl_clf, metric = "ROC"
)
knn_pred <- predict(knn_model, test)
confusionMatrix(knn_pred, test$Migrant_Status)
#---- Support Vector Machine (Radial)
svm_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "svmRadial",
tuneLength = 5, trControl = ctrl_clf, metric = "ROC"
)
svm_pred <- predict(svm_model, test)
confusionMatrix(svm_pred, test$Migrant_Status)
#---- Naive Bayes
nb_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "nb",
trControl = ctrl_clf, metric = "ROC"
)
results <- resamples(list(
LM = lm_model,
RF = rf_model,
GBM = gbm_model,
LOGIT = logit_model,
KNN = knn_model,
SVM = svm_model,
NB = nb_model,
NN = nn_model
))
summary(results)
bwplot(results)
dotplot(results)
#---- Naive Bayes
nb_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "nb",
trControl = ctrl_clf, metric = "ROC"
)
#---- Naive Bayes
nb_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "nb",
trControl = ctrl_clf, metric = "ROC"
)
nb_pred <- predict(nb_model, test)
confusionMatrix(nb_pred, test$Migrant_Status)
#---- Neural Network
nn_model <- train(
Migrant_Status ~ Age + Education_Level + Area_Type,
data = train, method = "nnet", tuneLength = 5,
trControl = ctrl_clf, metric = "ROC", trace = FALSE
)
nn_pred <- predict(nn_model, test)
confusionMatrix(nn_pred, test$Migrant_Status)
results <- resamples(list(
LM = lm_model,
RF = rf_model,
GBM = gbm_model,
LOGIT = logit_model,
KNN = knn_model,
SVM = svm_model,
NB = nb_model,
NN = nn_model
))
